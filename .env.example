# OLE Agent 凭证配置
# 复制此文件为 .env 并填入你的真实凭证

# HKMU OLE 登录凭证(学生账号)
OLE_USERNAME=your_student_id
OLE_PASSWORD=your_password

# LLM provider(OpenAI 兼容;可选:deepseek | glm | openai | ollama | custom)
LLM_PROVIDER=deepseek
LLM_API_KEY=your_api_key

# 可选覆盖(advanced):不填则用 LLM_PROVIDER 对应的预设 base_url / model
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
